#!/usr/bin/make -f

export DH_VERBOSE = 1

DEB_VERSION := $(shell dpkg-parsechangelog -S Version)
UPSTREAM_VERSION := $(shell echo $(DEB_VERSION) | sed 's/-[^-]*$$//')

%:
	dh $@

override_dh_auto_build:
	: nothing to build, we use prebuilt tarball content

override_dh_auto_install:
	# Same pattern as hgs: upstream from combined tarball (native format)
	# Build root is either . (we're inside hgs-qml) or has hgs-qml/ subdir
	SOURCE_DIR=""; \
	if [ -d hgs-qml ]; then SOURCE_DIR="hgs-qml"; \
	elif [ -f Modules/Greetd/assets/hgs-greeter ]; then SOURCE_DIR="."; \
	fi; \
	if [ -n "$$SOURCE_DIR" ]; then \
		mkdir -p debian/hgs-greeter/usr/share/quickshell/hgs-greeter && \
		( cd $$SOURCE_DIR && tar cf - --exclude=debian . ) | \
		( cd debian/hgs-greeter/usr/share/quickshell/hgs-greeter && tar xf - ) && \
		install -Dm755 $$SOURCE_DIR/Modules/Greetd/assets/hgs-greeter \
			debian/hgs-greeter/usr/bin/hgs-greeter && \
		install -Dm644 $$SOURCE_DIR/Modules/Greetd/README.md \
			debian/hgs-greeter/usr/share/doc/hgs-greeter/README.md && \
		install -Dm644 $$SOURCE_DIR/LICENSE \
			debian/hgs-greeter/usr/share/doc/hgs-greeter/LICENSE && \
		install -Dpm0644 $$SOURCE_DIR/systemd/tmpfiles-hgs-greeter.conf \
			debian/hgs-greeter/usr/lib/tmpfiles.d/hgs-greeter.conf && \
		install -Dm644 $$SOURCE_DIR/systemd/sysusers-hgs-greeter.conf \
			debian/hgs-greeter/usr/lib/sysusers.d/hgs-greeter.conf; \
	else \
		echo "ERROR: No upstream source (hgs-qml or Modules/Greetd/assets/hgs-greeter)!" && \
		echo "Contents of current directory:" && ls -la && exit 1; \
	fi

	# Remove build and development files
	rm -rf debian/hgs-greeter/usr/share/quickshell/hgs-greeter/core
	rm -rf debian/hgs-greeter/usr/share/quickshell/hgs-greeter/distro
	rm -rf debian/hgs-greeter/usr/share/quickshell/hgs-greeter/.git*
	rm -f debian/hgs-greeter/usr/share/quickshell/hgs-greeter/.gitignore
	rm -rf debian/hgs-greeter/usr/share/quickshell/hgs-greeter/.github

override_dh_auto_clean:
	rm -rf hgs-qml
	# When build root is hgs-qml itself, we're inside it - nothing extra to remove
	dh_auto_clean
