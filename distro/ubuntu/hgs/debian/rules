#!/usr/bin/make -f

export DH_VERBOSE = 1

# Extract version from debian/changelog
DEB_VERSION := $(shell dpkg-parsechangelog -S Version)
# Get upstream version (strip -1ppa1 suffix)
UPSTREAM_VERSION := $(shell echo $(DEB_VERSION) | sed 's/-[^-]*$$//')
# Strip ppa suffix and handle git versions
# Examples: 0.5.2ppa9 -> 0.5.2, 0.5.2+git20251116 -> 0.5.2
BASE_VERSION := $(shell echo $(UPSTREAM_VERSION) | sed 's/ppa[0-9]*$$//' | sed 's/+git.*//')

%:
	dh $@

override_dh_installsystemd:
	dh_installsystemd --name=hgs

override_dh_auto_build:
	# All files are included in source package (downloaded by build-source.sh)
	# Launchpad build environment has no internet access
	$(eval DEB_HOST_ARCH := $(shell dpkg-architecture -qDEB_HOST_ARCH))
	@echo "Building for architecture: $(DEB_HOST_ARCH)"

	test -f hgs-distropkg-$(DEB_HOST_ARCH).gz || (echo "ERROR: hgs-distropkg-$(DEB_HOST_ARCH).gz not found!" && exit 1)
	test -f hgs-source.tar.gz || (echo "ERROR: hgs-source.tar.gz not found!" && exit 1)

	# Extract pre-built binary
	gunzip -c hgs-distropkg-$(DEB_HOST_ARCH).gz > hgs
	chmod +x hgs

	# Extract source tarball for QML files
	tar -xzf hgs-source.tar.gz
	# Find the extracted directory (it might have various names)
	# and rename it to the expected BASE_VERSION name for consistent install
	SOURCE_DIR=$$(find . -maxdepth 1 -type d -name "HyprGlassShell-*" ! -name "HyprGlassShell-$(BASE_VERSION)" | head -n1); \
	if [ -n "$$SOURCE_DIR" ] && [ "$$SOURCE_DIR" != "./HyprGlassShell-$(BASE_VERSION)" ]; then \
		echo "Renaming $$SOURCE_DIR to HyprGlassShell-$(BASE_VERSION)"; \
		mv "$$SOURCE_DIR" HyprGlassShell-$(BASE_VERSION); \
	elif [ ! -d "HyprGlassShell-$(BASE_VERSION)" ]; then \
		echo "ERROR: No HyprGlassShell directory found after extraction!"; \
		ls -la; \
		exit 1; \
	fi

override_dh_auto_install:
	# Install binary
	install -Dm755 hgs debian/hgs/usr/bin/hgs

	# Install systemd user service (before copying everything else)
	install -Dm644 HyprGlassShell-$(BASE_VERSION)/assets/systemd/hgs.service \
		debian/hgs/usr/lib/systemd/user/hgs.service

	# Install desktop file and icon
	install -Dm644 HyprGlassShell-$(BASE_VERSION)/assets/hgs-open.desktop \
		debian/hgs/usr/share/applications/hgs-open.desktop
	install -Dm644 HyprGlassShell-$(BASE_VERSION)/assets/hgslogo.svg \
		debian/hgs/usr/share/icons/hicolor/scalable/apps/hgslogo.svg

	# Install QML files from source tarball
	mkdir -p debian/hgs/usr/share/quickshell/hgs
	cp -r HyprGlassShell-$(BASE_VERSION)/* debian/hgs/usr/share/quickshell/hgs/

	# Remove unnecessary directories
	rm -rf debian/hgs/usr/share/quickshell/hgs/core
	rm -rf debian/hgs/usr/share/quickshell/hgs/distro
	rm -rf debian/hgs/usr/share/quickshell/hgs/assets

	# Create VERSION file for Quickshell (stable release format)
	echo "$(BASE_VERSION)" > debian/hgs/usr/share/quickshell/hgs/VERSION

	# Generate and install shell completions (if applicable)
	# Uncomment if hgs supports completion generation
	# ./hgs completion bash > hgs.bash
	# ./hgs completion zsh > hgs.zsh
	# install -Dm644 hgs.bash debian/hgs/usr/share/bash-completion/completions/hgs
	# install -Dm644 hgs.zsh debian/hgs/usr/share/zsh/vendor-completions/_hgs

override_dh_auto_clean:
	rm -f hgs
	rm -rf HyprGlassShell-*
	# Don't remove hgs-distropkg-amd64.gz and hgs-source.tar.gz
	# They need to be included in the source package for Launchpad builds
	dh_auto_clean
