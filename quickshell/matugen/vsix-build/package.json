{
  "name": "hgs-theme",
  "displayName": "HGS - Hypr Glass Shell Theme",
  "description": "Dynamic theme using matugen & hgs16 terminal colors - auto-updated by HyprGlassShell",
  "publisher": "CoastLineSec",
  "version": "0.0.3",
  "icon": "hgslogo.png",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "hgs",
    "hgs",
    "material",
    "hgsshell",
    "coastlinesec"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/CoastLineSec/HyprGlassShell"
  },
  "contributes": {
    "themes": [
      {
        "label": "Dynamic Base16 HGSShell",
        "uiTheme": "vs-dark",
        "path": "./themes/hgsshell-default.json",
        "_watch": true
      },
      {
        "label": "Dynamic Base16 HGSShell (Dark)",
        "uiTheme": "vs-dark",
        "path": "./themes/hgsshell-dark.json",
        "_watch": true
      },
      {
        "label": "Dynamic Base16 HGSShell (Light)",
        "uiTheme": "vs",
        "path": "./themes/hgsshell-light.json",
        "_watch": true
      }
    ]
  }
}
